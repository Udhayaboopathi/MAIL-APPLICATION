# =========================
# PRODUCTION - Environment Template
# =========================
# For production, secrets are loaded from Docker secret files, NOT from this file.
# This file contains ONLY non-secret configuration values.
# 
# Sensitive values (passwords, tokens, keys) should be provided via Docker secrets:
# - ./secrets/POSTGRES_PASSWORD
# - ./secrets/DATABASE_URL
# - ./secrets/REDIS_URL
# - ./secrets/JWT_SECRET
# - ./secrets/JWT_REFRESH_SECRET
# - ./secrets/ENCRYPTION_KEY
#
# See docs/DEPLOYMENT.md for complete setup instructions.

# =========================
# DATABASE
# =========================
POSTGRES_DB=nexudo_mail
POSTGRES_USER=nexudo
# POSTGRES_PASSWORD: Load from ./secrets/POSTGRES_PASSWORD
# DATABASE_URL: Load from ./secrets/DATABASE_URL

# =========================
# REDIS
# =========================
# REDIS_URL: Load from ./secrets/REDIS_URL

# =========================
# AUTH & ENCRYPTION
# =========================
# JWT_SECRET: Load from ./secrets/JWT_SECRET
# JWT_REFRESH_SECRET: Load from ./secrets/JWT_REFRESH_SECRET
# ENCRYPTION_KEY: Load from ./secrets/ENCRYPTION_KEY
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=30
ENVIRONMENT=production

# =========================
# APP CONFIG (Change these to your domain)
# =========================
ROOT_DOMAIN=example.com
WEB_DOMAIN=example.com
API_DOMAIN=api.example.com
MAIL_DOMAIN=mail.example.com
SMTP_HOSTNAME=mail.example.com
SMTP_PORT=587

# =========================
# FRONTEND
# =========================
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_APP_NAME=Nexudo Mail

# =========================
# TRAEFIK & ACME (Change to your email)
# =========================
TRAEFIK_ACME_EMAIL=admin@example.com
