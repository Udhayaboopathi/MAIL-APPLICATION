# =========================
# DATABASE (External - update with your actual server)
# =========================
DATABASE_URL=postgresql+asyncpg://user:password@db.example.com:5432/dbname
REDIS_URL=redis://redis.example.com:6379/0

# =========================
# AUTH & ENCRYPTION
# =========================
JWT_SECRET=change-me-min-32-characters-long-really-long
JWT_REFRESH_SECRET=change-me-too-min-32-characters-long-really-long
ENCRYPTION_KEY=change-me-min-32-characters-long-really-long
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=30
ENVIRONMENT=production

# =========================
# APP CONFIG
# =========================
ROOT_DOMAIN=sudoinnovation.tech
WEB_DOMAIN=sudoinnovation.tech
API_DOMAIN=api.sudoinnovation.tech
MAIL_DOMAIN=mail.sudoinnovation.tech
SMTP_HOSTNAME=mail.sudoinnovation.tech
SMTP_PORT=587

# =========================
# FRONTEND
# =========================
NEXT_PUBLIC_API_BASE_URL=https://api.sudoinnovation.tech
NEXT_PUBLIC_APP_NAME=Nexudo Mail

# =========================
# TRAEFIK
# =========================
TRAEFIK_ACME_EMAIL=admin@sudoinnovation.tech
ADMIN_PASSWORD=Admin@123
